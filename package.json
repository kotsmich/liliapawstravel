{
  "name": "lilia-paws-travel",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start:user-portal": "ng serve user-app --port 4200 --configuration development",
    "start:admin-portal": "ng serve admin-app --port 4201 --configuration development",
    "start:api": "cd apps/api && npm run dev",
    "build": "ng build",
    "build:all": "nx run-many -t build -p user-app admin-app api",
    "watch:all": "concurrently \"ng build user-app --watch\" \"ng build admin-app --watch\" \"cd apps/api && npm run dev\"",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@angular/animations": "21.2.6",
    "@angular/cdk": "^21.0.0",
    "@angular/common": "21.2.6",
    "@angular/compiler": "21.2.6",
    "@angular/core": "21.2.6",
    "@angular/forms": "21.2.6",
    "@angular/platform-browser": "21.2.6",
    "@angular/platform-browser-dynamic": "21.2.6",
    "@angular/router": "21.2.6",
    "@angular/ssr": "^21.2.5",
    "@jsverse/transloco": "^8.2.1",
    "@ngrx/effects": "21.0.0",
    "@ngrx/store": "21.0.0",
    "@ngrx/store-devtools": "21.0.0",
    "@primeng/themes": "^21.0.4",
    "@primeuix/themes": "^2.0.3",
    "chart.js": "^4.5.1",
    "http-proxy-middleware": "^3.0.5",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.5",
    "@angular/cli": "21.2.5",
    "@angular/compiler-cli": "21.2.6",
    "@nx/angular": "22.6.3",
    "@nx/workspace": "22.6.3",
    "@types/jasmine": "~4.3.0",
    "concurrently": "^9.2.1",
    "jasmine-core": "~4.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "nx": "22.6.3",
    "typescript": "~5.9.0"
  }
}
