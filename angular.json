{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "user-app": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": { "style": "scss" }
      },
      "root": "apps/user-app",
      "sourceRoot": "apps/user-app/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/apps/user-app",
            "index": "apps/user-app/src/index.html",
            "main": "apps/user-app/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "apps/user-app/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": ["apps/user-app/src/favicon.ico", "apps/user-app/src/assets"],
            "styles": [
              "node_modules/primeicons/primeicons.css",
              "apps/user-app/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                { "type": "initial", "maximumWarning": "1mb", "maximumError": "2mb" },
                { "type": "anyComponentStyle", "maximumWarning": "10kb", "maximumError": "20kb" }
              ],
              "outputHashing": "all"
            },
            "development": {
              "fileReplacements": [
                {
                  "replace": "apps/user-app/src/environments/environment.ts",
                  "with": "apps/user-app/src/environments/environment.development.ts"
                }
              ],
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": { "browserTarget": "user-app:build:production" },
            "development": { "browserTarget": "user-app:build:development" }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": { "browserTarget": "user-app:build" }
        }
      }
    },
    "admin-app": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": { "style": "scss" }
      },
      "root": "apps/admin-app",
      "sourceRoot": "apps/admin-app/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/apps/admin-app",
            "index": "apps/admin-app/src/index.html",
            "main": "apps/admin-app/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "apps/admin-app/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": ["apps/admin-app/src/assets"],
            "styles": [
              "node_modules/primeicons/primeicons.css",
              "apps/admin-app/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                { "type": "initial", "maximumWarning": "1mb", "maximumError": "2mb" },
                { "type": "anyComponentStyle", "maximumWarning": "10kb", "maximumError": "20kb" }
              ],
              "outputHashing": "all"
            },
            "development": {
              "fileReplacements": [
                {
                  "replace": "apps/admin-app/src/environments/environment.ts",
                  "with": "apps/admin-app/src/environments/environment.development.ts"
                }
              ],
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": { "browserTarget": "admin-app:build:production" },
            "development": { "browserTarget": "admin-app:build:development" }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": { "browserTarget": "admin-app:build" }
        }
      }
    }
  }
}
