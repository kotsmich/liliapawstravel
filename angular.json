{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "user-app": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "apps/user-app",
      "sourceRoot": "apps/user-app/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/apps/user-app",
            "index": "apps/user-app/src/index.html",
            "browser": "apps/user-app/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "apps/user-app/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "apps/user-app/src/assets",
                "output": "assets"
              },
              {
                "glob": "favicon.ico",
                "input": "apps/user-app/src",
                "output": ""
              }
            ],
            "styles": [
              "node_modules/primeicons/primeicons.css",
              "node_modules/primeflex/primeflex.css",
              "apps/user-app/src/styles.scss"
            ],
            "scripts": [],
            "server": "apps/user-app/src/main.server.ts",
            "ssr": {
              "entry": "apps/user-app/src/server.ts"
            },
            "prerender": false,
            "externalDependencies": [
              "express",
              "http-proxy-middleware"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1mb",
                  "maximumError": "2mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "10kb",
                  "maximumError": "20kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "fileReplacements": [
                {
                  "replace": "apps/user-app/src/environments/environment.ts",
                  "with": "apps/user-app/src/environments/environment.development.ts"
                }
              ],
              "optimization": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "proxyConfig": "apps/user-app/proxy.conf.json"
          },
          "configurations": {
            "production": {
              "buildTarget": "user-app:build:production"
            },
            "development": {
              "buildTarget": "user-app:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "user-app:build"
          }
        }
      }
    },
    "admin-app": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "apps/admin-app",
      "sourceRoot": "apps/admin-app/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/apps/admin-app",
            "index": "apps/admin-app/src/index.html",
            "browser": "apps/admin-app/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "apps/admin-app/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "apps/admin-app/src/assets",
                "output": "assets"
              }
            ],
            "styles": [
              "node_modules/primeicons/primeicons.css",
              "node_modules/primeflex/primeflex.css",
              "apps/admin-app/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1mb",
                  "maximumError": "2mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "10kb",
                  "maximumError": "20kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "fileReplacements": [
                {
                  "replace": "apps/admin-app/src/environments/environment.ts",
                  "with": "apps/admin-app/src/environments/environment.development.ts"
                }
              ],
              "optimization": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "proxyConfig": "apps/admin-app/proxy.conf.json"
          },
          "configurations": {
            "production": {
              "buildTarget": "admin-app:build:production"
            },
            "development": {
              "buildTarget": "admin-app:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "admin-app:build"
          }
        }
      }
    }
  }
}